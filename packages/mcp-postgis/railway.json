{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install -g pnpm@9.15.9 && pnpm install --no-frozen-lockfile"
  },
  "deploy": {
    "startCommand": "node --import tsx/esm packages/mcp-postgis/src/index.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
